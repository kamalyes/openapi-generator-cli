{
  "name": "openapi-generator-cli",
  "version": "0.1.0",
  "description": "A lightweight TypeScript OpenAPI generator with module-oriented output.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "bin": {
    "openapi-generator-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "REFACTOR_PLAN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "node ./dist/cli.js",
    "generate": "node ./dist/cli.js generate",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.8.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.3"
  }
}
